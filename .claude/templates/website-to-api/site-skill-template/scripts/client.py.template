COOKIE_NAME = "COOKIE_NAME_HERE"
ENV_VAR = "SITE_UPPER_AUTH_COOKIE"


def _get_cookie(override: str | None = None) -> str:
    val = override or os.environ.get(ENV_VAR, "")
    if not val:
        console.print(
            f"[red]Error: No session cookie.[/red]\n"
            f"Set {ENV_VAR} env var or pass --cookie.\n"
            f"To get it: Chrome DevTools > Application > Cookies > {COOKIE_NAME}"
        )
        raise typer.Exit(1)
    return val


def _client(cookie: str) -> httpx.Client:
    return httpx.Client(
        cookies={COOKIE_NAME: cookie},
        headers={"User-Agent": "WebsiteToAPI/1.0"},
        follow_redirects=True,
        timeout=30.0,
    )


