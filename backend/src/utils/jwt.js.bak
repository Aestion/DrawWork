const jwt = require('jsonwebtoken')

const DEFAULT_JWT_SECRET = 'drawwork-secret-key'

function getJwtSecret() {
  const secret = process.env.JWT_SECRET || DEFAULT_JWT_SECRET
  if (process.env.NODE_ENV === 'production' && secret === DEFAULT_JWT_SECRET) {
    throw new Error('JWT_SECRET must be set to a strong non-default value in production')
  }
  return secret
}

function generateToken(user) {
  return jwt.sign(
    { userId: user.id, username: user.username, isAdmin: user.is_admin, type: 'access' },
    getJwtSecret(),
    { expiresIn: process.env.JWT_EXPIRES_IN || '24h' }
  )
}

function generateRefreshToken(user) {
  return jwt.sign(
    { userId: user.id, type: 'refresh' },
    getJwtSecret(),
    { expiresIn: process.env.JWT_REFRESH_EXPIRES_IN || '7d' }
  )
}

function verifyToken(token) {
  return jwt.verify(token, getJwtSecret())
}

module.exports = { generateToken, generateRefreshToken, verifyToken, getJwtSecret }
