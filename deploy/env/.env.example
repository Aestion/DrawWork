# DrawWork Docker 部署配置
# 复制此文件为 config/.env 并修改敏感配置项

# === 数据库配置 ===
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_strong_password
DB_NAME=drawwork
DB_PORT=5432

# === Redis 配置 ===
# 单实例部署可留空，多实例部署设置为 redis://redis:6379
REDIS_URL=

# === Minio 文件存储配置 ===
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_minio_password
MINIO_BUCKET=drawings
MINIO_USE_SSL=false

# === JWT 配置 ===
JWT_SECRET=CHANGE_ME_to_random_64_char_string
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# === API 配置 ===
PORT=3000
API_URL=http://localhost:3000
YJS_PORT=3001

# === 前端配置 ===
FRONTEND_URL=http://localhost
ALLOWED_ORIGINS=http://localhost,http://your-domain.com

# === 文件上传配置 ===
UPLOAD_MAX_SIZE=104857600
UPLOAD_ALLOWED_TYPES=image/*,video/*,audio/*

# === 环境模式 ===
NODE_ENV=production

# === 限流配置 ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=5

# === 日志配置 ===
LOG_LEVEL=info
LOG_FILE=logs/drawwork.log
